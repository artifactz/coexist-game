[gd_resource type="ShaderMaterial" format=3 uid="uid://dwb003bqdnbkd"]

[sub_resource type="Shader" id="Shader_ulksf"]
code = "shader_type spatial;
render_mode depth_draw_always, cull_back, unshaded;

uniform vec3 base_color = vec3(0.25, 0.25, 0.25);
uniform vec3 fog_color = vec3(0.071, 0.071, 0.071);
uniform float max_depth = 30.0;

void fragment() {
	float depth_r = 1.0 - clamp(-VERTEX.z / max_depth, 0.0, 1.0);
	depth_r *= depth_r;
	ALBEDO = mix(fog_color, base_color, depth_r);
}
"

[resource]
render_priority = 0
shader = SubResource("Shader_ulksf")
shader_parameter/base_color = Vector3(0.25, 0.25, 0.25)
shader_parameter/fog_color = Vector3(0.071, 0.071, 0.071)
shader_parameter/max_depth = 40.0
